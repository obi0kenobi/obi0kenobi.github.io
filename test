    <h1>Build Something Cool 🚀</h1>
    <p>This is my first real website</p>
    <br>
    <a class="btn" href="#">Get Started</a>
  </div>

  <!-- SERVICES -->
  <div class="section">
    <h2>What I Do</h2>

    <div class="card">
      <h3>Web Design</h3>
      <p>I make clean websites</p>
    </div>

    <div class="card">
      <h3>Gaming</h3>
      <p>I like games 🎮</p>
    </div>

    <div class="card">
      <h3>Random Stuff</h3>
      <p>More things soon...</p>
    </div>
  </div>

  <!-- FOOTER -->
  <div class="section">
    <p>Made by Caden 😎</p>
  </div>

</body>
</html>
