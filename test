<!DOCTYPE html>
<html>
<head>
  <title>Caden's Site</title>

  <style>
    body {
      margin: 0;
      font-family: Arial;
      background-color: #0f0f0f;
      color: white;
      text-align: center;
    }

    .hero {
      padding: 100px 20px;
    }

    h1 {
      font-size: 50px;
    }

    p {
      color: #aaa;
    }

    .btn {
      background: white;
